# =============================================================================
# MainStreet.shop — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
#
# SECURITY RULE: Only variables prefixed with NEXT_PUBLIC_ are exposed to the
# browser. Everything else is SERVER-ONLY and must never appear in client code.
# =============================================================================

# --- App -----------------------------------------------------------------
# Canonical production domain. Locally, leave as http://localhost:3000.
NEXT_PUBLIC_APP_URL=https://mainstreet-shops.com
ADMIN_EMAIL=admin@mainstreet-shops.com

# --- MongoDB Atlas (server-only) -----------------------------------------
# Atlas connection string. Create a cluster at cloud.mongodb.com.
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/mainstreet?retryWrites=true&w=majority

# --- Auth.js / NextAuth v5 (server-only) ---------------------------------
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth (console.cloud.google.com > Credentials > OAuth client ID)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Stripe (Connect + subscriptions) ------------------------------------
STRIPE_SECRET_KEY=sk_test_...                    # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # client-safe
STRIPE_WEBHOOK_SECRET=whsec_...                  # server-only (payments webhook)
STRIPE_CONNECT_CLIENT_ID=ca_...                  # Connect OAuth client id
# Stripe Price IDs (create in Stripe dashboard, test mode first)
STRIPE_PRICE_SELLER_ANNUAL=price_...             # $150/yr seller membership
STRIPE_PRICE_EXTRA_ITEMS_MONTHLY=price_...       # $5/mo per +50 items add-on

# --- EasyPost (rate quotes only) -----------------------------------------
EASYPOST_API_KEY=EZTK...                         # server-only, MASTER account
SHIPPING_MARKUP=1.85                             # hidden consumer-rate multiplier

# --- SL Pack & Ship fulfillment handoff ----------------------------------
SHIPIT_EMAIL=shipit@slpacknship.com              # where paid-order ship details are emailed

# --- Vercel Blob (object storage; server-only token) ---------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- Resend (transactional email; server-only) ---------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=hello@mainstreet-shops.com

# --- Upstash Redis (rate limiting; server-only) --------------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Google Maps (geocoding + map embed) ---------------------------------
GOOGLE_MAPS_API_KEY=AIza...                      # server-only, for geocoding
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...              # client, restrict to mainstreet.shop referrers

# --- AI (Claude) — event language moderation -----------------------------
# Used to screen community event submissions. If unset, a local keyword screen
# is used as a safe fallback. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# --- Amazon affiliate fallback (Addendum A) ------------------------------
AMAZON_ASSOCIATE_TAG=mainstreetus-20             # server-only
NEXT_PUBLIC_AMAZON_STOREFRONT_URL=https://www.amazon.com/shop/mainstreetus
